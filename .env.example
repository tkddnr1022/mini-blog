# Site (SEO absolute URLs, About, external links)
NEXT_PUBLIC_SITE_URL=https://example.com
NEXT_PUBLIC_AUTHOR=Your Name
NEXT_PUBLIC_GITHUB_URL=https://github.com/your-username
NEXT_PUBLIC_EMAIL=hello@example.com

# giscus (comments on post pages)
# 1. Enable GitHub Discussions on the repository
# 2. Install giscus at https://giscus.app and copy the IDs below
NEXT_PUBLIC_GISCUS_REPO=owner/repo
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=Announcements
NEXT_PUBLIC_GISCUS_CATEGORY_ID=

# Google Analytics 4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
